{
	"info": {
		"name": "Accommodation Controller Test",
		"description": "Postman collection for testing Accommodation controller in accommodation-service",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Create Accommodation",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Hotel Prague\",\n    \"address\": \"Prague 1\",\n    \"pricePerNight\": 100.0,\n    \"roomType\": \"Double\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/accommodations",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"accommodations"
					]
				}
			},
			"response": []
		},
		{
			"name": "Delete Accommodation",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{base_url}}/accommodations/1",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"accommodations",
						"1"
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8765",
			"type": "string"
		}
	]
}